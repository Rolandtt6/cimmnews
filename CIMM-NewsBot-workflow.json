#!/usr/bin/env python3
"""
Crypto Insider MM — Telegram News Bot
GitHub Actions version: python crypto_news_bot.py --once
Local schedule version: python crypto_news_bot.py
"""

import requests
import feedparser
import time
import json
import os
import sys
import hashlib
from datetime import datetime

# ── CONFIG ─────────────────────────────────────────────
# GitHub Actions: os.environ မှ ဖတ်သည် (secrets)
# Local run: ဒီမှာ တိုက်ရိုက်ထည့်နိုင်
BOT_TOKEN  = os.environ.get("BOT_TOKEN",  "8745293910:AAHOvztDgGjIxTVRywY9j1-ENlflXr749Tg")
CHANNEL_ID = os.environ.get("CHANNEL_ID", "-1003896067498")
SENT_FILE  = "sent_news.json"

# ── RSS SOURCES ────────────────────────────────────────
RSS_SOURCES = [
    {"name": "CoinTelegraph", "url": "https://cointelegraph.com/rss",                   "emoji": "📰"},
    {"name": "CoinDesk",      "url": "https://www.coindesk.com/arc/outboundfeeds/rss/", "emoji": "📊"},
    {"name": "Decrypt",       "url": "https://decrypt.co/feed",                         "emoji": "🔓"},
    {"name": "The Block",     "url": "https://www.theblock.co/rss.xml",                 "emoji": "⛓️"},
    {"name": "BeInCrypto",    "url": "https://beincrypto.com/feed/",                    "emoji": "🌐"},
    {"name": "Bitcoin Mag",   "url": "https://bitcoinmagazine.com/feed",                "emoji": "₿"},
]

BREAKING_KEYWORDS = [
    "bitcoin","btc","ethereum","eth","xrp","ripple",
    "solana","sol","etf","sec","fed","crash","surge",
    "hack","liquidat","ath","all-time high","rally"
]

# ── SENT HISTORY ───────────────────────────────────────
def load_sent():
    if os.path.exists(SENT_FILE):
        with open(SENT_FILE,"r") as f:
            return set(json.load(f))
    return set()

def save_sent(sent):
    with open(SENT_FILE,"w") as f:
        json.dump(list(sent)[-500:], f)

def news_id(title):
    return hashlib.md5(title.encode()).hexdigest()[:12]

# ── TELEGRAM ───────────────────────────────────────────
def send_msg(text):
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
    payload = {
        "chat_id": CHANNEL_ID,
        "text": text,
        "parse_mode": "HTML",
        "disable_web_page_preview": False
    }
    try:
        r = requests.post(url, json=payload, timeout=10)
        if r.status_code == 200:
            print(f"  ✅ Sent: {text[:60]}...")
            return True
        else:
            print(f"  ❌ {r.status_code}: {r.text[:100]}")
            return False
    except Exception as e:
        print(f"  ❌ Network: {e}")
        return False

# ── SENTIMENT ──────────────────────────────────────────
def get_sentiment(title):
    t = title.lower()
    bull = ["surge","soar","rally","gain","bull","rise","record","pump","approve","etf","breakout","ath","launch","adoption","high"]
    bear = ["crash","drop","fall","bear","dump","fear","hack","ban","plunge","collapse","scam","liquidat","warn","risk","low"]
    for w in bull:
        if w in t: return "📈 Bullish"
    for w in bear:
        if w in t: return "📉 Bearish"
    return "📊 Neutral"

def is_breaking(title):
    return any(kw in title.lower() for kw in BREAKING_KEYWORDS)

# ── FORMAT ─────────────────────────────────────────────
def format_news(item, source):
    sentiment = get_sentiment(item.get("title",""))
    breaking  = "🚨 BREAKING NEWS\n\n" if is_breaking(item.get("title","")) else ""
    title     = item.get("title","").strip()
    link      = item.get("link","").strip()
    pub_date  = item.get("published","")
    try:
        from email.utils import parsedate_to_datetime
        dt = parsedate_to_datetime(pub_date)
        time_str = dt.strftime("%b %d, %H:%M UTC")
    except:
        time_str = pub_date[:16] if pub_date else ""
    return (
        f"{breaking}"
        f"{source['emoji']} <b>{source['name']}</b>  |  {sentiment}\n\n"
        f"<b>{title}</b>\n\n"
        f"🔗 <a href='{link}'>Read Full Article</a>\n\n"
        f"⏰ {time_str}\n"
        f"━━━━━━━━━━━━━━━━━━\n"
        f"📡 Crypto Insider MM"
    )

# ── FETCH & POST ───────────────────────────────────────
def fetch_and_post():
    print(f"\n[{datetime.now().strftime('%H:%M:%S')}] Fetching news...")
    sent = load_sent()
    new_count = 0
    for source in RSS_SOURCES:
        try:
            print(f"  {source['name']}...")
            feed = feedparser.parse(source["url"])
            for entry in feed.entries[:5]:
                title = entry.get("title","").strip()
                if not title: continue
                nid = news_id(title)
                if nid in sent: continue
                if send_msg(format_news(entry, source)):
                    sent.add(nid)
                    new_count += 1
                    time.sleep(2)
        except Exception as e:
            print(f"  ❌ {source['name']}: {e}")
    save_sent(sent)
    print(f"  Done. {new_count} new articles posted.")

# ── MARKET OVERVIEW ────────────────────────────────────
def post_market_overview():
    try:
        url = "https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&ids=bitcoin,ethereum,binancecoin,solana,ripple&order=market_cap_desc&sparkline=false&price_change_percentage=24h"
        coins = requests.get(url, timeout=10).json()
        g = requests.get("https://api.coingecko.com/api/v3/global", timeout=10).json()
        mcap = g["data"]["total_market_cap"]["usd"]
        vol  = g["data"]["total_volume"]["usd"]
        def fmt_price(p):
            if p >= 1000: return "${:,.0f}".format(p)
            if p >= 1:    return "${:.2f}".format(p)
            return "${:.4f}".format(p)
        def fmt_big(v):
            if v >= 1e12: return "${:.2f}T".format(v/1e12)
            if v >= 1e9:  return "${:.2f}B".format(v/1e9)
            return "${:.0f}M".format(v/1e6)
        lines = []
        for c in coins:
            chg = c.get("price_change_percentage_24h") or 0
            lines.append("{} <b>{}</b>: {}  ({:+.1f}%)".format(
                "🟢" if chg >= 0 else "🔴", c["symbol"].upper(), fmt_price(c["current_price"]), chg))
        fg = requests.get("https://api.alternative.me/fng/?limit=1", timeout=8).json()
        fgv = fg["data"][0]["value"]; fgl = fg["data"][0]["value_classification"]
        msg = ("📊 <b>Crypto Market Overview</b>\n\n" + "\n".join(lines) +
               f"\n\n📈 Market Cap: <b>{fmt_big(mcap)}</b>\n"
               f"💹 24h Volume: <b>{fmt_big(vol)}</b>\n\n"
               f"⚡ Fear &amp; Greed: <b>{fgv} — {fgl}</b>\n"
               f"━━━━━━━━━━━━━━━━━━\n📡 Crypto Insider MM")
        send_msg(msg)
    except Exception as e:
        print(f"  ❌ Market overview: {e}")

# ── FEAR & GREED ───────────────────────────────────────
def post_fear_greed():
    try:
        data = requests.get("https://api.alternative.me/fng/?limit=2", timeout=8).json()["data"]
        v = int(data[0]["value"]); lbl = data[0]["value_classification"]
        emoji = "😱" if v<25 else "😨" if v<45 else "😐" if v<55 else "😏" if v<75 else "🤑"
        bar = "█"*int(v/10) + "░"*(10-int(v/10))
        msg = (f"📊 <b>Fear &amp; Greed Index</b>\n\n"
               f"{emoji} <b>{v} — {lbl}</b>\n\n[{bar}] {v}/100\n\n"
               f"Yesterday: {data[1]['value']} ({data[1]['value_classification']})\n"
               f"━━━━━━━━━━━━━━━━━━\n📡 Crypto Insider MM | {datetime.now().strftime('%b %d, %Y')}")
        send_msg(msg)
    except Exception as e:
        print(f"  ❌ Fear & Greed: {e}")

# ── MAIN ───────────────────────────────────────────────
def run_once():
    """GitHub Actions mode — run once and exit"""
    print("=" * 50)
    print("  Crypto Insider MM — One-shot run")
    print("=" * 50)
    hour = datetime.now().hour
    # 9:00 AM UTC — Fear & Greed + Market Overview
    if hour == 9:
        post_fear_greed()
        post_market_overview()
    # Every run — fetch news
    fetch_and_post()

def run_scheduled():
    """Local mode — run with schedule"""
    import schedule
    print("=" * 50)
    print("  Crypto Insider MM — Scheduled mode")
    print("=" * 50)
    post_market_overview()
    fetch_and_post()
    schedule.every(1).hours.do(fetch_and_post)
    schedule.every(4).hours.do(post_market_overview)
    schedule.every().day.at("09:00").do(post_fear_greed)
    schedule.every().day.at("09:05").do(post_market_overview)
    print("\nBot running... Ctrl+C to stop\n")
    while True:
        schedule.run_pending()
        time.sleep(30)

if __name__ == "__main__":
    if "--once" in sys.argv:
        run_once()
    else:
        run_scheduled()
